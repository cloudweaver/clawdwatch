# Clawdwatch Configuration

# Region to monitor: middle_east | europe | usa | asia
WATCH_REGION=middle_east

# LLM Provider (local or api)
CLAWDWATCH_MODE=local
OLLAMA_MODEL=dolphin-mixtral:8x7b

# Optional: xAI API (if using cloud mode)
XAI_API_KEY=

# Data Sources (OpenSky Network is free, no key needed)
MARINE_TRAFFIC_API_KEY=
SENTINEL_HUB_API_KEY=

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Optional
TWITTER_BEARER_TOKEN=
